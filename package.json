{
  "name": "trello-clone",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @trello/web",
    "dev:api": "npm run dev --workspace @trello/api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  }
}
